{
  "name": "Event",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "event",
        "podcast",
        "talk",
        "cohort",
        "workshop"
      ],
      "default": "event"
    },
    "college_id": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "time": {
      "type": "string"
    },
    "venue": {
      "type": "string"
    },
    "mentor_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "upcoming",
        "live",
        "completed",
        "cancelled"
      ],
      "default": "upcoming"
    },
    "attendees_count": {
      "type": "number",
      "default": 0
    },
    "student_response": {
      "type": "string"
    },
    "suggestions": {
      "type": "string"
    },
    "report": {
      "type": "string"
    },
    "added_by": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "college_id"
  ]
}
